{
    "name": "board/plugin-shelf",
    "description": "Shelf — a document board type for Board: file-explorer tree, collaborative markdown notes (TipTap + Yjs) and file storage under a quota.",
    "type": "library",
    "license": "MIT",
    "keywords": ["board", "kanban", "shelf", "documents", "notes", "markdown"],
    "require": {
        "php": "^8.3",
        "board/plugin-sdk": "^0.2.8"
    },
    "autoload": {
        "psr-4": {
            "Board\\PluginShelf\\": "src/"
        }
    },
    "extra": {
        "board": {
            "sdk_contract": 1
        },
        "laravel": {
            "providers": [
                "Board\\PluginShelf\\ShelfServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
